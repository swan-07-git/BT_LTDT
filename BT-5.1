import time

epoch_seconds = time.time()

days_since_epoch = int(epoch_seconds // (24 * 60 * 60))

current_seconds = int(epoch_seconds % (24 * 60 * 60))
hours = current_seconds // 3600
minutes = (current_seconds % 3600) // 60
seconds = current_seconds % 60

print("Days since epoch:", days_since_epoch)
print("Current time (GMT): {:02d}:{:02d}:{:02d}".format(hours, minutes, seconds))
